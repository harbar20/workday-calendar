{
    "manifest_version": 3,
    "name": "Catonaut",
    "version": "0.1.0",
    "content_scripts": [
        {
            "matches": ["https://*/*"],
            "js": ["content.js"],
            "css": ["content.css"]
        }
    ],
    "icons": {
        "16": "assets/images/icon16.png",
        "32": "assets/images/icon32.png",
        "48": "assets/images/icon48.png",
        "128": "assets/images/icon128.png"
    },
    "permissions": ["activeTab"],
    "web_accessible_resources": [
        {
            "resources": ["index.html", "assets/*"],
            "matches": ["https://*/*"]
        }
    ]
}
